# Cloudflare credentials used by deploy_backend.sh
CLOUDFLARE_API_TOKEN=replace-me
CLOUDFLARE_ACCOUNT_ID=replace-me

# Optional global health check fallback
BACKEND_HEALTHCHECK_URL=

# Staging release environment
BACKEND_STAGING_WORKER_NAME=glassgpt-staging
BACKEND_STAGING_APP_ENV=staging
BACKEND_STAGING_WORKERS_DEV=true
BACKEND_STAGING_D1_DATABASE_NAME=replace-me
BACKEND_STAGING_D1_DATABASE_ID=replace-me
BACKEND_STAGING_R2_BUCKET_NAME=replace-me
BACKEND_STAGING_CORS_ALLOWED_ORIGINS=https://staging.glassgpt.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
BACKEND_STAGING_HEALTHCHECK_URL=

# Production release environment
BACKEND_PRODUCTION_WORKER_NAME=glassgpt-production
BACKEND_PRODUCTION_APP_ENV=production
BACKEND_PRODUCTION_WORKERS_DEV=true
BACKEND_PRODUCTION_D1_DATABASE_NAME=replace-me
BACKEND_PRODUCTION_D1_DATABASE_ID=replace-me
BACKEND_PRODUCTION_R2_BUCKET_NAME=replace-me
BACKEND_PRODUCTION_CORS_ALLOWED_ORIGINS=https://glassgpt.com,https://beta.glassgpt.com
BACKEND_PRODUCTION_HEALTHCHECK_URL=
