{
  "name": "@glassgpt/backend-contracts",
  "version": "5.4.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "default": "./dist/fixtures.js"
    }
  },
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "generate": "tsx src/generate-artifacts.ts",
    "test": "vitest run --config vitest.config.ts",
    "ci": "tsx src/generate-artifacts.ts && rm -rf dist && tsc -p tsconfig.build.json && vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "zod": "4.3.6"
  }
}
